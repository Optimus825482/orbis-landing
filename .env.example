# ═══════════════════════════════════════════════════════════════
# ORBIS Landing — Coolify env template
# Copy to `.env` and fill in. Coolify can also inject these.
# ═══════════════════════════════════════════════════════════════

# Public-facing domain (DNS A/CNAME target)
DOMAIN=orbisastro.online

# Container identity (used by docker-compose ${CONTAINER_NAME})
CONTAINER_NAME=orbis-landing

# Internal port the container listens on (Coolify reverse-proxies this)
PUBLIC_PORT=80

# Timezone for log timestamps
TZ=Europe/Istanbul

# ═══════════════════════════════════════════════════════════════
# Mode B (optional): Cloudflare Proxy OFF + Origin Certificate
# Only set these if you switched to nginx/cf-origin.conf
# ═══════════════════════════════════════════════════════════════
# CF_ORIGIN_CERT_PATH=./certs
# CF_ORIGIN_CERT_FILE=origin.pem
# CF_ORIGIN_KEY_FILE=origin.key
